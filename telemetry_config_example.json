{
  "version": "1.0.0",
  "protocol_version": "1.0",
  "endianness": "little",
  "alignment": "arm",
  "sensors": [
    {
      "id": 1,
      "name": "temperature",
      "description": "Ambient temperature from the main sensor",
      "data_type": "float32",
      "units": "C",
      "scale": 0.01,
      "display_format": "{value:.2f} °C",
      "default_value": 0.0
    },
    {
      "id": 2,
      "name": "status_flags",
      "description": "Device status bit flags",
      "data_type": "uint8",
      "units": "bits"
    },
    {
      "id": 3,
      "name": "imu_reading",
      "description": "IMU sample block containing accel and gyro values",
      "data_type": "struct",
      "struct_fields": [
        {"name": "accel_x", "data_type": "float32", "units": "m/s^2"},
        {"name": "accel_y", "data_type": "float32", "units": "m/s^2"},
        {"name": "accel_z", "data_type": "float32", "units": "m/s^2"},
        {"name": "gyro_x", "data_type": "float32", "units": "deg/s"},
        {"name": "gyro_y", "data_type": "float32", "units": "deg/s"},
        {"name": "gyro_z", "data_type": "float32", "units": "deg/s"}
      ]
    },
    {
        "id": 4,
        "name": "battery_status",
        "description": "Battery voltage, current, and temperature",
        "data_type": "struct",
        "struct_fields": [
            { "name": "voltage_mv", "data_type": "uint16", "units": "mV" },
            { "name": "current_ma", "data_type": "int16", "units": "mA" },
            { "name": "temperature_c", "data_type": "float32", "units": "°C" }
        ]
    },
    {
    "id": 5,
    "name": "device_label",
    "description": "Device label string",
    "data_type": "string",
    "default_value": "STM32-01"
    },
    {
    "id": 6,
    "name": "raw_data",
    "description": "Raw telemetry byte payload",
    "data_type": "bytes",
    "count": 8
    }
  ]
}
